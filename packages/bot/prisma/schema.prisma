// ══════════════════════════════════════════════════════════════════════════════
// Kami-Sama Bot — Prisma Schema
// ══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Warnings ─────────────────────────────────────────────────────────────────

model Warning {
  id        String   @id @default(cuid())
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  reason    String
  moderator String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([guildId, userId, id], name: "warning_unique")
  @@index([guildId, userId])
  @@map("warnings")
}

// ── Incidents ────────────────────────────────────────────────────────────────

model Incident {
  id        String   @id @default(cuid())
  code      String   @unique
  guildId   String?  @map("guild_id")
  title     String
  severity  String // "low" | "major" | "critical"
  status    String   @default("investigating") // "investigating" | "resolved"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("incidents")
}

// ── Support Tickets ──────────────────────────────────────────────────────────

model Ticket {
  id           String    @id @default(cuid())
  channelId    String    @unique @map("channel_id")
  guildId      String    @map("guild_id")
  ownerId      String    @map("owner_id")
  language     String?
  topic        String? // "account" | "billing" | "technical" | "community" | "other"
  claimedById  String?   @map("claimed_by_id")
  claimedByTag String?   @map("claimed_by_tag")
  claimedAt    DateTime? @map("claimed_at")
  closedAt     DateTime? @map("closed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([guildId])
  @@index([ownerId])
  @@map("tickets")
}

// ── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  guildId   String   @map("guild_id")
  action    String
  actor     String
  target    String?
  targetId  String?  @map("target_id")
  reason    String?
  metadata  Json? // action-specific data (deleteDays, warnId, total, previous, new, etc.)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt(sort: Desc)])
  @@index([guildId, action])
  @@map("audit_log")
}

// ── XP System ────────────────────────────────────────────────────────────────

model XpProfile {
  id           String    @id @default(cuid())
  guildId      String    @map("guild_id")
  userId       String    @map("user_id")
  totalXp      Int       @default(0) @map("total_xp")
  messageCount Int       @default(0) @map("message_count")
  lastXpAt     DateTime? @map("last_xp_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([guildId, userId])
  @@index([guildId, totalXp(sort: Desc)])
  @@map("xp_profiles")
}

// ── Guild Configuration ──────────────────────────────────────────────────────

model GuildConfig {
  id      String @id @default(cuid())
  guildId String @unique @map("guild_id")

  // Member events toggle
  memberEventsEnabled Boolean @default(true) @map("member_events_enabled")

  // Welcome settings
  welcomeEnabled    Boolean  @default(false) @map("welcome_enabled")
  welcomeChannelId  String?  @map("welcome_channel_id")
  welcomeRoleIds    String[] @map("welcome_role_ids")
  welcomeMessage    String?  @map("welcome_message")
  welcomeFormat     String?  @default("embed") @map("welcome_format") // "text" | "embed"
  welcomeColor      Int?     @default(5793266) @map("welcome_color") // 0x5865F2
  welcomeDmEnabled  Boolean  @default(false) @map("welcome_dm_enabled")
  welcomeIgnoreBots Boolean  @default(true) @map("welcome_ignore_bots")

  // Goodbye settings
  goodbyeEnabled    Boolean @default(false) @map("goodbye_enabled")
  goodbyeChannelId  String? @map("goodbye_channel_id")
  goodbyeMessage    String? @map("goodbye_message")
  goodbyeFormat     String? @default("embed") @map("goodbye_format") // "text" | "embed"
  goodbyeColor      Int?    @default(15622109) @map("goodbye_color") // 0xED4245
  goodbyeIgnoreBots Boolean @default(true) @map("goodbye_ignore_bots")

  // Panel settings
  panelChannelId String?   @map("panel_channel_id")
  panelMessageId String?   @map("panel_message_id")
  panelUpdatedAt DateTime? @map("panel_updated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guild_configs")
}

// ── Notification Channels ────────────────────────────────────────────────────

model NotificationChannel {
  id        String @id @default(cuid())
  guildId   String @map("guild_id")
  type      String // "server_info" | "infra_info" | "social_network" | "status"
  channelId String @map("channel_id")

  @@unique([guildId, type])
  @@map("notification_channels")
}

// ── Polls ────────────────────────────────────────────────────────────────────

model Poll {
  id        String    @id @default(cuid())
  guildId   String    @map("guild_id")
  channelId String    @map("channel_id")
  messageId String    @map("message_id")
  question  String
  choices   String[]
  authorId  String    @map("author_id")
  authorTag String    @map("author_tag")
  expiresAt DateTime? @map("expires_at")
  ended     Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([guildId, messageId])
  @@index([guildId, ended])
  @@map("polls")
}

model PollVote {
  id        String @id @default(cuid())
  pollId    String @map("poll_id")
  userId    String @map("user_id")
  choiceIdx Int    @map("choice_index")

  @@unique([pollId, userId])
  @@map("poll_votes")
}

// ── Deployment State ─────────────────────────────────────────────────────────

model DeploymentState {
  id                      String    @id @default(cuid())
  lastAnnouncedDeployment String?   @map("last_announced_deployment")
  announcedAt             DateTime? @map("announced_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("deployment_state")
}
