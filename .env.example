# ── Cloud / Dokploy configuration ───────────────────
DOMAIN_HOST=kami-sama.tv
APP_IMAGE_TAG=cloud
DATABASE_URL=postgresql://postgres:rxza2cfem5b4mwcx@enterprise-website-db-company-website-syj4x5:5432/companywebsite
SECRET_KEY=mu4ubzbfjejs2zcshri1omrcex6unikd2rlmbfreofoqcdx4hy3eynfngonnm64p
PRISMA_SCHEMA_DEPLOY=true
PRISMA_SCHEMA_DEPLOY_STRATEGY=push

# ── Logging ──────────────────────────────────────────
# Supported levels: debug, info, warn, error.
LOG_LEVEL=info
# Set to true only when diagnosing frontend HTTP requests.
HTTP_ACCESS_LOGS=false
# Set to true only when diagnosing API HTTP requests.
API_ACCESS_LOGS=false
# This project currently has no dedicated worker; keep false unless a future worker needs DB startup gating.
WORKER_WAIT_FOR_DB=false

# ── Redis (Optional) ───────────────────────────────────
REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_PASSWORD=mu4ubzbfjejs2zcshri1omrcex6unikd2rlmbfreofoqcdx4hy3eynfngonnm64p
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
REDIS_KEY_PREFIX=kami-sama:v1
REDIS_DEFAULT_TTL=300
REDIS_CONNECT_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
REDIS_MAX_RETRIES=3

# ── Migration Failure (Emergency Only) ─────────────
# Set to true only if you need to start the container despite failed migrations.
# Never enable this in production without manual verification.
ALLOW_MIGRATION_FAILURE=false


# Port sur lequel le serveur écoute
PORT=8080

# Clé système pour les requêtes internes de l'application
SYSTEM_KEY=sk_system_default_key_change_in_production

# URL du frontend (pour les redirections OAuth)
FRONTEND_URL=http://localhost:3000

# OAuth Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

# OAuth GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/github/callback

# OAuth Discord
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=
OAUTH_DISCORD_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/discord/callback

# OAuth Apple
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/apple/callback

# Durée de validité du state OAuth (défaut: 10m)
OAUTH_STATE_TTL=10m
